{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Run act build analysis",
         "type": "shell",
         "command": "act",
         "args": [
            "push",
            "--pull=false",
            "-P",
            "ubuntu-24.04=act-ubuntu:24.04",
            "-j",
            "build"
         ],
         "isBackground": false,
         "group": "build"
      },
      {
         "label": "Run act PR",
         "type": "shell",
         "command": "act",
         "args": [
            "workflow_dispatch",
            "-W",
            ".github/workflows/pr-tests.yml",
            "--pull=false",
            "-P",
            "ubuntu-24.04=act-ubuntu:24.04",
            "-j",
            "enforce-coverage"
         ],
         "isBackground": false,
         "group": "build"
      },
      {
         "label": "Generate Coverage",
         "type": "shell",
         "command": "powershell",
         "args": [
            "-Command",
            "Expand-Archive -Path build/artifacts/1/promise-coverage/promise-coverage.zip -DestinationPath build/gcov/ -Force"
         ],
         "problemMatcher": [],
         "group": "test"
      }
   ]
}
